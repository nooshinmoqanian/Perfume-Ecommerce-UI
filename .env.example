# Set these to the full origin (no trailing slash) if you want frontend to call services directly.
# If empty, frontend will use relative `/api` paths (and Vite dev proxy if configured).

# Order service base origin (e.g. http://localhost:3001)
VITE_ORDERS_BASE=http://localhost:3001

# Inventory (product) service base origin (e.g. http://localhost:3002)
VITE_PRODUCTS_BASE=http://localhost:3002
